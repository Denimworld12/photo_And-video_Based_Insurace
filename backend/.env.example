# ==============================================
# PBI AgriInsure - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret (change this to a strong random string)
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio Configuration (for SMS OTP)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_phone_number

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Python Configuration
PYTHON_COMMAND=python
WEATHER_API_KEY=your_weather_api_key

# File Upload
MAX_FILE_SIZE=52428800

# Admin Configuration
ADMIN_PHONE_NUMBER=6392398104

# OTP Configuration
# Set to 'false' to enable real SMS via Twilio
OTP_MOCK_MODE=true

# Google Gemini AI (for claim summarization)
GEMINI_API_KEY=your_gemini_api_key_here

# Claim Threshold Configuration
# Confidence >= APPROVE threshold → auto-approved
# Confidence >= REJECT threshold → manual review
# Confidence < REJECT threshold → auto-rejected
CLAIM_AUTO_APPROVE_THRESHOLD=0.7
CLAIM_REJECT_THRESHOLD=0.3
